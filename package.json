{
  "name": "geobuke-code",
  "version": "0.5.0",
  "description": "거북이코드 — 계획↔구현↔검증 게이트. Claude Code PreToolUse hook으로 구현 전 계획 케이스 누락·시나리오 미지정을 차단하고, gbc verify로 구현 후 케이스를 증거(JUnit·코드 독해)와 대조한다(verified>reviewed>unverifiable).",
  "type": "module",
  "bin": {
    "gbc": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test 'test/**/*.test.mjs'",
    "eval": "node dist/eval/regression.js",
    "prepare": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "release": "sh scripts/publish.sh"
  },
  "keywords": [
    "claude-code",
    "hook",
    "gate",
    "pre-implementation",
    "post-implementation",
    "verify",
    "junit",
    "code-review"
  ],
  "license": "MIT",
  "author": "cubha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cubha/geobuke-code.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
